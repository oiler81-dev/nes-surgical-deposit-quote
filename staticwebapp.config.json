{
  "routes": [
    {
      "route": "/admin.html",
      "allowedRoles": ["admin"]
    },
    {
      "route": "/api/reports/*",
      "allowedRoles": ["admin"]
    },
    {
      "route": "/*",
      "allowedRoles": ["authenticated"]
    }
  ],
  "responseOverrides": {
    "401": {
      "statusCode": 302,
      "redirect": "/.auth/login/aad"
    },
    "403": {
      "rewrite": "/403.html"
    }
  }
}
