{
  "routes": [
    { "route": "/admin.html", "allowedRoles": ["admin"] },

    { "route": "/api/admin-report", "allowedRoles": ["admin"] },

    { "route": "/api/*", "allowedRoles": ["authenticated"] },

    { "route": "/*", "allowedRoles": ["authenticated"] }
  ],
  "responseOverrides": {
    "401": {
      "statusCode": 302,
      "redirect": "/.auth/login/aad"
    },
    "403": {
      "rewrite": "/403.html"
    }
  }
}
